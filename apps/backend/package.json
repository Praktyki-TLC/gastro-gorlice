{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:db:seed": "tsx --env-file=../../.env drizzle/scripts/seed.ts",
    "build": "echo 'Skipping tsc build, using tsx for runtime'",
    "start": "tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx drizzle/scripts/seed.ts"
  },
  "imports": {
    "#shared/*": "../../shared/*.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.11",
    "cron": "^4.4.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "playwright": "^1.58.2",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "dotenv": "^17.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}